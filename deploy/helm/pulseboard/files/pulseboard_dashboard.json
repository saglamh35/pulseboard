      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "queryText": "SELECT CAST(strftime('%s', MIN(date)) AS INTEGER) AS time, SUM(value) AS weekly_steps FROM health_metrics WHERE metric = 'steps' AND aggregation = 'sum' GROUP BY strftime('%Y-%W', date) ORDER BY time",
          "rawQueryText": "SELECT CAST(strftime('%s', MIN(date)) AS INTEGER) AS time, SUM(value) AS weekly_steps FROM health_metrics WHERE metric = 'steps' AND aggregation = 'sum' GROUP BY strftime('%Y-%W', date) ORDER BY time",
