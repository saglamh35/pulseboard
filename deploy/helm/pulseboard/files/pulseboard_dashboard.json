        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
