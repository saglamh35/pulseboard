      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "queryText": "SELECT CAST(strftime('%s', date) AS INTEGER) AS time, AVG(value) OVER (ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS sleep_7d_avg FROM health_metrics WHERE metric = 'sleep_hours' AND aggregation = 'sum' ORDER BY date",
          "rawQueryText": "SELECT CAST(strftime('%s', date) AS INTEGER) AS time, AVG(value) OVER (ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS sleep_7d_avg FROM health_metrics WHERE metric = 'sleep_hours' AND aggregation = 'sum' ORDER BY date",
