    {
      "id": 12,
      "type": "timeseries",
      "title": "Sleep stages per night",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "pulseboard-sqlite"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 42
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "queryText": "SELECT CAST(strftime('%s', date) AS INTEGER) AS time, SUM(CASE WHEN metric = 'sleep_core_hours' THEN value END) AS core, SUM(CASE WHEN metric = 'sleep_deep_hours' THEN value END) AS deep, SUM(CASE WHEN metric = 'sleep_rem_hours' THEN value END) AS rem, SUM(CASE WHEN metric = 'sleep_awake_hours' THEN value END) AS awake FROM health_metrics WHERE metric IN ('sleep_core_hours','sleep_deep_hours','sleep_rem_hours','sleep_awake_hours') AND aggregation = 'sum' GROUP BY date ORDER BY date",
          "rawQueryText": "SELECT CAST(strftime('%s', date) AS INTEGER) AS time, SUM(CASE WHEN metric = 'sleep_core_hours' THEN value END) AS core, SUM(CASE WHEN metric = 'sleep_deep_hours' THEN value END) AS deep, SUM(CASE WHEN metric = 'sleep_rem_hours' THEN value END) AS rem, SUM(CASE WHEN metric = 'sleep_awake_hours' THEN value END) AS awake FROM health_metrics WHERE metric IN ('sleep_core_hours','sleep_deep_hours','sleep_rem_hours','sleep_awake_hours') AND aggregation = 'sum' GROUP BY date ORDER BY date",
          "timeColumns": [
            "time"
          ]
        }
