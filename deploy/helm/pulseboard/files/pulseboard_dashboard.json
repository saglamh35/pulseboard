          "rawQueryText": "SELECT CAST(strftime('%s', date) AS INTEGER) AS time, value AS resting_hr, AVG(value) OVER (ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS resting_hr_7d_avg FROM health_metrics WHERE metric = 'resting_heart_rate' AND aggregation = 'avg' ORDER BY date",
