    {
      "id": 5,
      "type": "timeseries",
      "title": "Steps per day",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "pulseboard-sqlite"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "queryText": "SELECT CAST(strftime('%s', date) AS INTEGER) AS time, value AS steps FROM health_metrics WHERE metric = 'steps' AND aggregation = 'sum' ORDER BY date",
          "rawQueryText": "SELECT CAST(strftime('%s', date) AS INTEGER) AS time, value AS steps FROM health_metrics WHERE metric = 'steps' AND aggregation = 'sum' ORDER BY date",
          "timeColumns": [
            "time"
