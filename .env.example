# Copy to .env (git-ignored) and fill in what you use. NEVER commit a real
# .env — this repository is public and these variables can hold API keys.
# docker compose reads .env automatically for the ${VAR:-} substitutions.

# --- Notifications (docs/REPORTS.md) ---
#PULSEBOARD_NTFY_URL=https://ntfy.sh
#PULSEBOARD_NTFY_TOPIC=your-secret-topic
#PULSEBOARD_NTFY_TOKEN=
#PULSEBOARD_TELEGRAM_BOT_TOKEN=
#PULSEBOARD_TELEGRAM_CHAT_ID=

# --- AI weekly coach, opt-in (docs/AI_COACH.md) ---
# Provider: ollama (local, default choice — data stays on your machine),
# or anthropic / openai / gemini (cloud; the report digest is sent to them).
#PULSEBOARD_AI_PROVIDER=ollama
#PULSEBOARD_AI_MODEL=gemma3:4b
#PULSEBOARD_OLLAMA_URL=http://127.0.0.1:11434
# Cloud keys — set only the one your provider needs, and only ever here/env:
#PULSEBOARD_ANTHROPIC_API_KEY=sk-ant-your-key-here
#PULSEBOARD_OPENAI_API_KEY=sk-your-key-here
#PULSEBOARD_GEMINI_API_KEY=your-key-here

# --- API auth (docs/INGEST.md) ---
#PULSEBOARD_API_TOKEN=
